# AI Chat manual/default preset for Life Command Center
#
# Use this to keep routing effectively off and preserve the existing edge-first behavior.

AI_CHAT_POLICY=manual
AI_CHAT_PROVIDER=edge
AI_CHAT_MODEL=gpt-5-mini

# No feature-level routing overrides
AI_CHAT_FEATURE_PROVIDERS=
AI_CHAT_FEATURE_MODELS=

# Optional upstream requirements
# EDGE_FUNCTION_URL=...

