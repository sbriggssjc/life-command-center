+// Strip noise from owner strings that came in from CoStar / public records:
+//   trademark / registered marks, redundant whitespace, leading/trailing
+//   commas. Keeps "Davita Inc." readable as "Davita Inc."
+function _udSanitizeOwner(s) {
+  if (!s) return '';
+  return String(s)
+    .replace(/[®™]/g, '')
+    .replace(/\s+/g, ' ')
+    .replace(/[\s,]+$/, '')
+    .replace(/^[\s,]+/, '')
+    .trim();
+}
