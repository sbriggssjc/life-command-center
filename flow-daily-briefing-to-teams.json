{
  "name": "flow-daily-briefing-to-teams",
  "description": "Scheduled read-only Daily Briefing delivery from LCC snapshot endpoint to Teams channel.",
  "trigger": {
    "type": "Recurrence",
    "suggested_schedule": "Weekdays 07:30 America/Chicago"
  },
  "parameters": {
    "LCC_HOST": {
      "type": "string",
      "example": "https://<your-lcc-host>"
    },
    "LCC_API_KEY": {
      "type": "securestring"
    },
    "WORKSPACE_ID": {
      "type": "string"
    },
    "ROLE_VIEW": {
      "type": "string",
      "allowed": [
        "broker",
        "analyst_ops"
      ],
      "default": "broker"
    },
    "TEAMS_TEAM_ID": {
      "type": "string"
    },
    "TEAMS_CHANNEL_ID": {
      "type": "string"
    }
  },
  "steps": [
    {
      "name": "HTTP_GetDailyBriefingSnapshot",
      "type": "HTTP",
      "method": "GET",
      "uri": "@{concat(parameters('LCC_HOST'), '/api/daily-briefing?action=snapshot&role_view=', parameters('ROLE_VIEW'))}",
      "headers": {
        "x-lcc-key": "@{parameters('LCC_API_KEY')}",
        "x-lcc-workspace": "@{parameters('WORKSPACE_ID')}",
        "Content-Type": "application/json"
      }
    },
    {
      "name": "Compose_CardBindingData",
      "type": "Compose",
      "mapping_notes": [
        "Build compact joined strings for priorities/highlights before binding card.",
        "Use coalesce() to keep degraded scenarios readable."
      ],
      "outputs_template": {
        "lcc_base_url": "@{parameters('LCC_HOST')}",
        "role_view": "@{coalesce(body('HTTP_GetDailyBriefingSnapshot')?['role_view'], parameters('ROLE_VIEW'))}",
        "as_of_display": "@{coalesce(body('HTTP_GetDailyBriefingSnapshot')?['as_of'], 'unknown')}",
        "summary_headline": "@{coalesce(body('HTTP_GetDailyBriefingSnapshot')?['global_market_intelligence']?['summary'], 'No market summary available')}",
        "completeness_status": "@{coalesce(body('HTTP_GetDailyBriefingSnapshot')?['status']?['completeness'], 'unknown')}",
        "top_priorities_text": "@{coalesce(first(body('HTTP_GetDailyBriefingSnapshot')?['user_specific_priorities']?['today_top_5'])?['title'], 'No priorities in snapshot')}",
        "work_open_actions": "@{string(coalesce(body('HTTP_GetDailyBriefingSnapshot')?['team_level_production_signals']?['work_counts']?['open_actions'], 0))}",
        "work_inbox_new": "@{string(coalesce(body('HTTP_GetDailyBriefingSnapshot')?['team_level_production_signals']?['work_counts']?['inbox_new'], 0))}",
        "work_sync_errors": "@{string(coalesce(body('HTTP_GetDailyBriefingSnapshot')?['team_level_production_signals']?['work_counts']?['sync_errors'], 0))}",
        "government_highlights_text": "@{coalesce(first(body('HTTP_GetDailyBriefingSnapshot')?['domain_specific_alerts_highlights']?['government']?['highlights']), 'None')}",
        "dialysis_highlights_text": "@{coalesce(first(body('HTTP_GetDailyBriefingSnapshot')?['domain_specific_alerts_highlights']?['dialysis']?['highlights']), 'None')}",
        "is_degraded": "@{equals(body('HTTP_GetDailyBriefingSnapshot')?['status']?['completeness'], 'degraded')}",
        "degraded_note": "@{if(equals(body('HTTP_GetDailyBriefingSnapshot')?['status']?['completeness'], 'degraded'), concat('Missing sections: ', join(body('HTTP_GetDailyBriefingSnapshot')?['status']?['missing_sections'], ', ')), '')}"
      }
    },
    {
      "name": "Teams_PostAdaptiveCardInChannel",
      "type": "Teams",
      "action": "Post adaptive card in a channel",
      "team_id": "@{parameters('TEAMS_TEAM_ID')}",
      "channel_id": "@{parameters('TEAMS_CHANNEL_ID')}",
      "template_file": "docs/architecture/teams_daily_briefing_adaptive_card.json",
      "template_data": "@{outputs('Compose_CardBindingData')}"
    }
  ]
}

