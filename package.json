{
  "name": "life-command-center",
  "version": "2.1.0",
  "private": true,
  "description": "Full-stack operational platform — shared team queue, inbox triage, entity management, sync orchestration",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "start:railway": "NODE_ENV=production node server.js",
    "dev": "node server.js",
    "verify:deploy": "node scripts/verify-deploy.mjs",
  "check:boot": "node scripts/check-boot.mjs",
    "lint": "eslint api/ --ext .js",
    "ai:routing": "node scripts/print-ai-chat-routing.mjs",
    "ai:status": "node scripts/ai-rollout-status.mjs",
    "ai:preview-balanced": "node scripts/preview-ai-chat-preset.mjs AI_CHAT_BALANCED_PRESET.env.example",
    "ai:preview-low-cost": "node scripts/preview-ai-chat-preset.mjs AI_CHAT_LOW_COST_PRESET.env.example",
    "ai:preview-manual": "node scripts/preview-ai-chat-preset.mjs AI_CHAT_MANUAL_EDGE_PRESET.env.example",
    "ai:apply-balanced": "node scripts/apply-ai-chat-preset.mjs AI_CHAT_BALANCED_PRESET.env.example --target .env.local",
    "ai:apply-low-cost": "node scripts/apply-ai-chat-preset.mjs AI_CHAT_LOW_COST_PRESET.env.example --target .env.local",
    "ai:apply-manual": "node scripts/apply-ai-chat-preset.mjs AI_CHAT_MANUAL_EDGE_PRESET.env.example --target .env.local",
    "test": "node --test test/*.test.js test/*.test.mjs",
    "test:watch": "node --test --watch test/*.test.js test/*.test.mjs",
    "cm:refresh-catalog-snapshot": "node scripts/cm-refresh-catalog-snapshot.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.0",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  }
}
