# AI Chat low-cost rollout preset for Life Command Center
#
# Use this after the balanced rollout is stable and you want to push more traffic
# toward local/low-cost providers.

AI_CHAT_POLICY=manual
AI_CHAT_PROVIDER=ollama
AI_CHAT_MODEL=llama3.1

# Keep the most ambiguous flow on stronger API reasoning.
AI_CHAT_FEATURE_PROVIDERS={"detail_ownership_assistant":"openai","global_copilot":"ollama"}

# Use vision locally for intake screenshots and keep ownership on a stronger API model.
AI_CHAT_FEATURE_MODELS={"detail_intake_assistant":"llama3.2-vision","detail_intel_assistant":"llama3.1","ops_research_assistant":"llama3.1","global_copilot":"llama3.1","detail_ownership_assistant":"gpt-5-mini"}

# OpenAI path requirements
# OPENAI_API_KEY=...

# Ollama path requirements
# AI_API_BASE_URL=http://localhost:11434

