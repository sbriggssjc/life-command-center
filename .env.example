# Life Command Center — Environment Variables
# Copy this file to .env.local for local development

# Government Supabase (domain database)
GOV_SUPABASE_URL=
GOV_SUPABASE_KEY=

# Dialysis Supabase (domain database)
DIA_SUPABASE_URL=
DIA_SUPABASE_KEY=

# Ops Supabase (canonical model — shared team platform)
OPS_SUPABASE_URL=
OPS_SUPABASE_KEY=

# Edge Function base URL (ai-copilot deployment)
EDGE_FUNCTION_URL=

# Morning briefing integration (Daily Briefing Agent orchestration)
MORNING_BRIEFING_STRUCTURED_URL=  # JSON payload URL from Morning briefing engine
MORNING_BRIEFING_HTML_URL=        # Optional HTML briefing URL

# AI orchestration
AI_CHAT_PROVIDER=edge   # edge | openai | ollama | disabled
AI_CHAT_URL=            # optional override for chat proxy target
AI_CHAT_MODEL=gpt-5-mini
AI_CHAT_POLICY=manual   # manual | balanced
# Example staged rollout:
# AI_CHAT_POLICY=balanced
# AI_CHAT_FEATURE_PROVIDERS={"detail_ownership_assistant":"openai","global_copilot":"edge"}
# AI_CHAT_FEATURE_MODELS={"detail_intake_assistant":"llama3.2-vision","detail_ownership_assistant":"gpt-5-mini"}
AI_CHAT_FEATURE_PROVIDERS=  # optional JSON, e.g. {"detail_intake_assistant":"ollama","detail_ownership_assistant":"openai"}
AI_CHAT_FEATURE_MODELS=     # optional JSON, e.g. {"detail_intake_assistant":"llama3.2-vision","global_copilot":"gpt-5-mini"}
AI_PROVIDER=openai      # openai | ollama | disabled
AI_MODEL=gpt-5-mini
AI_API_BASE_URL=        # optional OpenAI-compatible base URL or local Ollama URL
AI_TIMEOUT_S=60
OPENAI_API_KEY=

# Power Automate: Complete SF Task flow URL (closes original open tasks)
PA_COMPLETE_TASK_URL=

# Power Automate: New lead webhook URL (notified when a GovLease prospect lead is inserted)
PA_NEW_LEAD_WEBHOOK_URL=https://prod-XX.westus.logic.azure.com/workflows/REPLACE_ME/triggers/manual/paths/invoke?api-version=2016-06-01

# Intake Entity Extraction
INTAKE_EXTRACTION_ENABLED=true
INTERNAL_EMAIL_DOMAINS=northmarq.com,example.com

# Auth
# LCC_API_KEY is REQUIRED for the /api/property endpoint (strict X-LCC-Key
# enforcement for Railway MCP get_property_context parity) and Power Automate
# integrations. Other endpoints fall back to transitional dev auth when unset.
LCC_API_KEY=           # Required for /api/property + Power Automate
LCC_ENV=development    # production | staging | development

# Government Write Service (FastAPI closed-loop write endpoints)
GOV_API_URL=           # e.g. https://gov-api.example.com

# Diagnostics
DIAG_SECRET=           # Secret token for /api/diag endpoint

# WebEx Integration (call history + messaging + SMS)
WEBEX_ACCESS_TOKEN=    # WebEx OAuth user token (scopes: spark:calls_read, spark:people_read, spark:messages_read, spark:messages_write)

# Microsoft Graph API (Teams messaging)
MS_GRAPH_TOKEN=        # Delegated OAuth token (scopes: Chat.Read, Chat.ReadWrite)

# Teams Push Alerts (event-triggered notifications via incoming webhook)
TEAMS_INTAKE_WEBHOOK_URL=   # Power Automate incoming webhook URL for deal alerts
LCC_BASE_URL=               # e.g., https://lcc-production.up.railway.app
TEAMS_COLD_ALERTS_ENABLED=false
