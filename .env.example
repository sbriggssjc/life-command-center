# Life Command Center — Environment Variables
# Copy this file to .env.local for local development

# Government Supabase (domain database)
GOV_SUPABASE_URL=
GOV_SUPABASE_KEY=

# Dialysis Supabase (domain database)
DIA_SUPABASE_URL=
DIA_SUPABASE_KEY=

# Ops Supabase (canonical model — shared team platform)
OPS_SUPABASE_URL=
OPS_SUPABASE_KEY=

# Edge Function base URL (ai-copilot deployment)
EDGE_FUNCTION_URL=

# Auth
LCC_API_KEY=           # Internal dev/CI API key
LCC_ENV=development    # production | staging | development

# Government Write Service (FastAPI closed-loop write endpoints)
GOV_API_URL=           # e.g. https://gov-api.example.com

# Diagnostics
DIAG_SECRET=           # Secret token for /api/diag endpoint
