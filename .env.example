# Life Command Center — Environment Variables
# Copy this file to .env.local for local development

# Government Supabase (domain database)
GOV_SUPABASE_URL=
GOV_SUPABASE_KEY=

# Dialysis Supabase (domain database)
DIA_SUPABASE_URL=
DIA_SUPABASE_KEY=

# Ops Supabase (canonical model — shared team platform)
OPS_SUPABASE_URL=
OPS_SUPABASE_KEY=

# Edge Function base URL (ai-copilot deployment)
EDGE_FUNCTION_URL=

# AI orchestration
AI_CHAT_PROVIDER=edge   # edge | openai | disabled
AI_CHAT_URL=            # optional override for chat proxy target
AI_CHAT_MODEL=gpt-5-mini
AI_PROVIDER=openai      # openai | ollama | disabled
AI_MODEL=gpt-5-mini
AI_API_BASE_URL=        # optional OpenAI-compatible base URL or local Ollama URL
AI_TIMEOUT_S=60
OPENAI_API_KEY=

# Power Automate: Complete SF Task flow URL (closes original open tasks)
PA_COMPLETE_TASK_URL=

# Auth
LCC_API_KEY=           # Internal dev/CI API key
LCC_ENV=development    # production | staging | development

# Government Write Service (FastAPI closed-loop write endpoints)
GOV_API_URL=           # e.g. https://gov-api.example.com

# Diagnostics
DIAG_SECRET=           # Secret token for /api/diag endpoint

# WebEx Integration (call history + messaging + SMS)
WEBEX_ACCESS_TOKEN=    # WebEx OAuth user token (scopes: spark:calls_read, spark:people_read, spark:messages_read, spark:messages_write)

# Microsoft Graph API (Teams messaging)
MS_GRAPH_TOKEN=        # Delegated OAuth token (scopes: Chat.Read, Chat.ReadWrite)
