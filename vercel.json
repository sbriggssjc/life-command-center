{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "",
  "rewrites": [
    { "source": "/api/config", "destination": "/api/diagnostics?_route=config" },
    { "source": "/api/diag", "destination": "/api/diagnostics?_route=diag" },
    { "source": "/api/treasury", "destination": "/api/diagnostics?_route=treasury" },
    { "source": "/api/gov-query", "destination": "/api/data-proxy?_source=gov" },
    { "source": "/api/gov-write", "destination": "/api/data-proxy?_route=gov-write" },
    { "source": "/api/gov-evidence", "destination": "/api/data-proxy?_route=gov-evidence" },
    { "source": "/api/dia-query", "destination": "/api/data-proxy?_source=dia" },
    { "source": "/api/activities", "destination": "/api/actions?_route=activities" },
    { "source": "/api/workspaces", "destination": "/api/admin?_route=workspaces" },
    { "source": "/api/members", "destination": "/api/admin?_route=members" },
    { "source": "/api/flags", "destination": "/api/admin?_route=flags" },
    { "source": "/api/auth-config", "destination": "/api/admin?_route=auth-config" },
    { "source": "/api/me", "destination": "/api/admin?_route=me" },
    { "source": "/api/queue-v2", "destination": "/api/queue?_version=v2" },
    { "source": "/api/rcm-ingest", "destination": "/api/sync?_route=rcm-ingest" },
    { "source": "/api/rcm-backfill", "destination": "/api/sync?_route=rcm-backfill" },
    { "source": "/api/copilot-spec", "destination": "/api/operations?_route=chat&copilot_spec=openapi" },
    { "source": "/api/copilot-manifest", "destination": "/api/operations?_route=chat&copilot_spec=manifest" },
    { "source": "/api/chat", "destination": "/api/operations?_route=chat" },
    { "source": "/api/draft", "destination": "/api/operations?_route=draft" },
    { "source": "/api/live-ingest", "destination": "/api/sync?_route=live-ingest" },
    { "source": "/api/loopnet-ingest", "destination": "/api/sync?_route=loopnet-ingest" },
    { "source": "/api/lead-health", "destination": "/api/sync?_route=lead-health" },
    { "source": "/api/listing-webhook", "destination": "/api/sync?_route=listing-webhook" },
    { "source": "/api/connectors", "destination": "/api/sync?_route=connectors" },
    { "source": "/api/unified-contacts", "destination": "/api/entity-hub?_domain=contacts" },
    { "source": "/api/contacts", "destination": "/api/entity-hub?_domain=contacts" },
    { "source": "/api/entities", "destination": "/api/entity-hub?_domain=entities" },
    { "source": "/api/bridge", "destination": "/api/operations" },
    { "source": "/api/workflows", "destination": "/api/operations" },
    { "source": "/api/intake-outlook-message", "destination": "/api/intake?_route=outlook-message" },
    { "source": "/api/intake-summary", "destination": "/api/intake?_route=summary" },
    { "source": "/api/inbox", "destination": "/api/queue?_route=inbox" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-XSS-Protection", "value": "0" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}