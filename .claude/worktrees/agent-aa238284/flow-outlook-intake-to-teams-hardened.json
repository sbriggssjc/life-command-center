{
  "name": "flow-outlook-intake-to-teams-hardened",
  "trigger": "When an email is flagged (V3)",
  "http_step_1": {
    "method": "POST",
    "uri": "https://<LCC_HOST>/api/intake-outlook-message",
    "headers": {
      "Content-Type": "application/json",
      "x-lcc-key": "<LCC_API_KEY>",
      "x-lcc-workspace": "<WORKSPACE_ID>"
    },
    "body_template": {
      "message_id": "@{triggerOutputs()?['body/id']}",
      "internet_message_id": "@{triggerOutputs()?['body/internetMessageId']}",
      "subject": "@{triggerOutputs()?['body/subject']}",
      "from": "@{triggerOutputs()?['body/from']}",
      "body_preview": "@{triggerOutputs()?['body/bodyPreview']}",
      "received_date_time": "@{triggerOutputs()?['body/receivedDateTime']}",
      "web_link": "@{triggerOutputs()?['body/webLink']}",
      "has_attachments": "@{triggerOutputs()?['body/hasAttachments']}",
      "attachments": "@{triggerOutputs()?['body/attachments']}"
    }
  },
  "http_step_2": {
    "method": "GET",
    "uri": "https://<LCC_HOST>/api/intake-summary?correlation_id=@{body('HTTP_step_1')?['correlation_id']}&limit=1",
    "headers": {
      "x-lcc-key": "<LCC_API_KEY>",
      "x-lcc-workspace": "<WORKSPACE_ID>"
    }
  },
  "teams_step": {
    "action": "Post adaptive card in channel",
    "template_file": "docs/architecture/teams_outlook_intake_adaptive_card.json"
  }
}
