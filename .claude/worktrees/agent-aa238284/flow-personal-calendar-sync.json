{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "$connections": {
        "defaultValue": {},
        "type": "Object"
      }
    },
    "triggers": {
      "Recurrence": {
        "type": "Recurrence",
        "recurrence": {
          "frequency": "Hour",
          "interval": 1
        }
      }
    },
    "actions": {
      "Initialize_AllEvents": {
        "type": "InitializeVariable",
        "inputs": {
          "variables": [
            {
              "name": "AllEvents",
              "type": "array",
              "value": []
            }
          ]
        },
        "runAfter": {}
      },
      "Get_Calendar_Events": {
        "type": "ApiConnection",
        "inputs": {
          "host": {
            "connection": {
              "name": "@parameters('$connections')['outlookcom']['connectionId']"
            }
          },
          "method": "get",
          "path": "/calendars/calendar/calendarview",
          "queries": {
            "startDateTimeUtc": "@{addDays(utcNow(), -1)}",
            "endDateTimeUtc": "@{addDays(utcNow(), 30)}"
          }
        },
        "runAfter": {
          "Initialize_AllEvents": ["Succeeded"]
        }
      },
      "Loop_Each_Event": {
        "type": "Foreach",
        "foreach": "@body('Get_Calendar_Events')?['value']",
        "actions": {
          "Append_Event": {
            "type": "AppendToArrayVariable",
            "inputs": {
              "name": "AllEvents",
              "value": {
                "Id": "personal-@{items('Loop_Each_Event')?['id']}",
                "Subject": "@{items('Loop_Each_Event')?['subject']}",
                "Start": "@{items('Loop_Each_Event')?['start']}",
                "End": "@{items('Loop_Each_Event')?['end']}",
                "Location": "@{items('Loop_Each_Event')?['location']?['displayName']}",
                "IsAllDay": "@{items('Loop_Each_Event')?['isAllDay']}",
                "Organizer": "@{items('Loop_Each_Event')?['organizer']?['emailAddress']?['address']}",
                "BodyPreview": "@{substring(coalesce(items('Loop_Each_Event')?['bodyPreview'], ''), 0, min(length(coalesce(items('Loop_Each_Event')?['bodyPreview'], '')), 300))}",
                "WebLink": "@{items('Loop_Each_Event')?['webLink']}",
                "IsRecurring": "@{items('Loop_Each_Event')?['isRecurrence']}",
                "CalendarName": "personal",
                "Sensitivity": "@{items('Loop_Each_Event')?['sensitivity']}",
                "ShowAs": "@{items('Loop_Each_Event')?['showAs']}"
              }
            },
            "runAfter": {}
          }
        },
        "runAfter": {
          "Get_Calendar_Events": ["Succeeded"]
        }
      },
      "POST_To_Supabase": {
        "type": "Http",
        "inputs": {
          "method": "POST",
          "uri": "https://zqzrriwuavgrquhisnoa.supabase.co/functions/v1/ai-copilot/sync/calendar-events",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "events": "@variables('AllEvents')"
          }
        },
        "runAfter": {
          "Loop_Each_Event": ["Succeeded"]
        }
      }
    }
  },
  "connectionReferences": {
    "outlookcom": {
      "api": {
        "id": "/providers/Microsoft.PowerApps/apis/shared_outlook"
      },
      "connection": {
        "id": "CONFIGURE_AT_IMPORT"
      },
      "connectionName": "shared-outlook"
    }
  }
}
