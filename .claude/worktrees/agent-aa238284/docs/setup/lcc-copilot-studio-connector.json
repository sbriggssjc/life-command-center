{
  "swagger": "2.0",
  "info": {
    "title": "Life Command Center",
    "description": "CRE deal intelligence API for Team Briggs at Northmarq. Provides daily briefings, pipeline intelligence, contact prioritization, entity search, and work queue metrics.",
    "version": "1.0.0",
    "contact": {
      "name": "Scott Briggs",
      "email": "sbriggssjc@gmail.com"
    }
  },
  "host": "life-command-center-nine.vercel.app",
  "basePath": "/",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "paths": {
    "/api/copilot/portfolio/get-daily-briefing-snapshot": {
      "post": {
        "operationId": "GetDailyBriefing",
        "summary": "Get Daily Briefing",
        "description": "Returns today's prioritized daily briefing with strategic, important, and urgent items requiring attention. Call this when the user asks what to focus on, wants a morning briefing, or asks about daily priorities.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "timeframe": {
                  "type": "string",
                  "description": "Time range for the briefing",
                  "enum": ["today", "since_yesterday", "this_week"],
                  "default": "today",
                  "x-ms-summary": "Timeframe"
                },
                "domain": {
                  "type": "string",
                  "description": "Filter by business domain",
                  "enum": ["government", "dialysis", "both"],
                  "default": "both",
                  "x-ms-summary": "Domain"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily briefing with prioritized items",
            "schema": {
              "type": "object",
              "properties": {
                "briefing": {
                  "type": "object",
                  "description": "Structured briefing with priority sections"
                },
                "generated_at": {
                  "type": "string",
                  "description": "Timestamp when briefing was generated"
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/portfolio/get-hot-business-contacts": {
      "post": {
        "operationId": "GetHotContacts",
        "summary": "Get Hot Business Contacts",
        "description": "Returns high-priority business development contacts with recent activity or upcoming touchpoints. Call this when the user asks who to call, wants prospecting targets, or asks about warm contacts.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "domain": {
                  "type": "string",
                  "description": "Filter by business domain",
                  "enum": ["government", "dialysis"],
                  "x-ms-summary": "Domain"
                },
                "limit": {
                  "type": "integer",
                  "description": "Maximum number of contacts to return (1-50)",
                  "default": 10,
                  "x-ms-summary": "Limit"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Hot business contacts with activity context",
            "schema": {
              "type": "object",
              "properties": {
                "contacts": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  },
                  "description": "Hot lead contacts with activity context"
                },
                "count": {
                  "type": "integer",
                  "description": "Number of contacts returned"
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/portfolio/search-entity-targets": {
      "post": {
        "operationId": "SearchEntities",
        "summary": "Search Entities",
        "description": "Search canonical entities (contacts, organizations, assets) by name across all types. Call this when the user asks about a specific property, contact, or company by name.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["q"],
              "properties": {
                "q": {
                  "type": "string",
                  "description": "Search query — property name, contact name, or organization name",
                  "x-ms-summary": "Search Query"
                },
                "entity_type": {
                  "type": "string",
                  "description": "Filter by entity type",
                  "enum": ["contact", "organization", "asset"],
                  "x-ms-summary": "Entity Type"
                },
                "domain": {
                  "type": "string",
                  "description": "Filter by business domain",
                  "enum": ["government", "dialysis"],
                  "x-ms-summary": "Domain"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching entities",
            "schema": {
              "type": "object",
              "properties": {
                "entities": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  },
                  "description": "Matching entities with metadata"
                },
                "count": {
                  "type": "integer",
                  "description": "Number of matches"
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/portfolio/get-pipeline-intelligence": {
      "post": {
        "operationId": "GetPipelineIntelligence",
        "summary": "Get Pipeline Intelligence",
        "description": "Returns deal pipeline health — velocity, conversion rates, bottleneck analysis across domains. Call this when the user asks about pipeline, deals, what's stuck, or conversion rates.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "domain": {
                  "type": "string",
                  "description": "Filter by business domain",
                  "enum": ["government", "dialysis", "both"],
                  "default": "both",
                  "x-ms-summary": "Domain"
                },
                "timeframe": {
                  "type": "string",
                  "description": "Analysis period",
                  "enum": ["30d", "90d", "6m", "1y"],
                  "default": "90d",
                  "x-ms-summary": "Timeframe"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pipeline metrics and analysis",
            "schema": {
              "type": "object",
              "properties": {
                "intelligence": {
                  "type": "object",
                  "description": "Pipeline metrics and analysis"
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/ops/get-work-counts": {
      "post": {
        "operationId": "GetWorkCounts",
        "summary": "Get Work Counts",
        "description": "Returns aggregate work counts — open actions, inbox items, overdue tasks, by domain and priority. Call this when the user asks about workload, task counts, overdue items, or queue status.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "domain": {
                  "type": "string",
                  "description": "Filter by business domain",
                  "enum": ["government", "dialysis"],
                  "x-ms-summary": "Domain"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Categorized work counts",
            "schema": {
              "type": "object",
              "properties": {
                "counts": {
                  "type": "object",
                  "description": "Categorized work counts by domain and priority"
                }
              }
            }
          }
        }
      }
    }
  },
  "securityDefinitions": {},
  "security": []
}
