{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "$connections": {
        "defaultValue": {},
        "type": "Object"
      }
    },
    "triggers": {
      "When_a_new_email_arrives_(V2)": {
        "type": "ApiConnectionNotification",
        "inputs": {
          "host": {
            "connection": {
              "name": "@parameters('$connections')['outlookcom']['connectionId']"
            }
          },
          "fetch": {
            "pathTemplate": {
              "template": "/Mail/OnNewEmail"
            },
            "method": "get",
            "queries": {
              "folderPath": "Inbox",
              "importance": "Any",
              "fetchOnlyWithAttachment": false,
              "includeAttachments": false,
              "subjectFilter": "",
              "flaggedOnly": true
            }
          },
          "subscribe": {
            "body": {
              "NotificationUrl": "@{listCallbackUrl()}"
            },
            "pathTemplate": {
              "template": "/Mail/OnNewEmailPokeSubscription"
            },
            "method": "post",
            "queries": {
              "folderPath": "Inbox",
              "importance": "Any",
              "fetchOnlyWithAttachment": false,
              "includeAttachments": false,
              "flaggedOnly": true
            }
          }
        }
      }
    },
    "actions": {
      "Initialize_TargetList": {
        "type": "InitializeVariable",
        "inputs": {
          "variables": [
            {
              "name": "TargetList",
              "type": "string",
              "value": "Personal"
            }
          ]
        },
        "runAfter": {}
      },
      "Categorize_By_Sender": {
        "type": "Switch",
        "expression": "@toLower(triggerOutputs()?['body/from'])",
        "cases": {
          "School": {
            "case": "REPLACE_WITH_SCHOOL_EMAIL",
            "actions": {
              "Set_Kids": {
                "type": "SetVariable",
                "inputs": {
                  "name": "TargetList",
                  "value": "Kids"
                }
              }
            }
          },
          "Doctor": {
            "case": "REPLACE_WITH_DOCTOR_EMAIL",
            "actions": {
              "Set_Health": {
                "type": "SetVariable",
                "inputs": {
                  "name": "TargetList",
                  "value": "Health"
                }
              }
            }
          },
          "Bank": {
            "case": "REPLACE_WITH_BANK_EMAIL",
            "actions": {
              "Set_Finance": {
                "type": "SetVariable",
                "inputs": {
                  "name": "TargetList",
                  "value": "Finance"
                }
              }
            }
          },
          "Insurance": {
            "case": "REPLACE_WITH_INSURANCE_EMAIL",
            "actions": {
              "Set_House": {
                "type": "SetVariable",
                "inputs": {
                  "name": "TargetList",
                  "value": "House"
                }
              }
            }
          }
        },
        "default": {
          "actions": {
            "Keep_Personal_Default": {
              "type": "Compose",
              "inputs": "Default: Personal list"
            }
          }
        },
        "runAfter": {
          "Initialize_TargetList": ["Succeeded"]
        }
      },
      "Create_To_Do_Task": {
        "type": "ApiConnection",
        "inputs": {
          "host": {
            "connection": {
              "name": "@parameters('$connections')['todo']['connectionId']"
            }
          },
          "method": "post",
          "path": "/v1.0/me/todo/lists/@{variables('TargetList')}/tasks",
          "body": {
            "title": "@{triggerOutputs()?['body/subject']}",
            "importance": "high",
            "body": {
              "content": "📧 From: @{triggerOutputs()?['body/from']}\n📅 Received: @{triggerOutputs()?['body/receivedDateTime']}\n🏷️ Source: Personal (Outlook.com)\n\n@{substring(triggerOutputs()?['body/bodyPreview'], 0, min(length(triggerOutputs()?['body/bodyPreview']), 500))}\n\n---\n[EmailID:@{triggerOutputs()?['body/id']}]\n[EmailSource:personal]",
              "contentType": "text"
            }
          }
        },
        "runAfter": {
          "Categorize_By_Sender": ["Succeeded"]
        }
      }
    }
  },
  "connectionReferences": {
    "outlookcom": {
      "api": {
        "id": "/providers/Microsoft.PowerApps/apis/shared_outlook"
      },
      "connection": {
        "id": "CONFIGURE_AT_IMPORT"
      },
      "connectionName": "shared-outlook",
      "connectionProperties": {
        "authentication": {
          "type": "oauthSetting",
          "oauthSettings": {
            "identity": "PERSONAL_MICROSOFT_ACCOUNT"
          }
        }
      }
    },
    "todo": {
      "api": {
        "id": "/providers/Microsoft.PowerApps/apis/shared_todo"
      },
      "connection": {
        "id": "CONFIGURE_AT_IMPORT"
      },
      "connectionName": "shared-todo"
    }
  }
}
