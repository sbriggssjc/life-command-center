    "/api/copilot/ops/get-sync-run-health": {
      "post": {
        "operationId": "get_sync_run_health",
        "summary": "Check health status of all sync connectors — Salesforce, Outlook, domain databases.",
        "description": "**Tier 0** (read-only). Category: ops.",
        "tags": [
          "ops"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "connectors": {
                      "type": "array",
                      "description": "Connector health statuses"
                    },
                    "overall_status": {
                      "type": "string",
                      "enum": [
                        "healthy",
                        "degraded",
                        "error"
                      ]
                    }
                  }
                }
              }
            }
