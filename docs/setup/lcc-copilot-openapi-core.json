{
  "openapi": "3.0.3",
  "info": {
    "title": "Life Command Center — Copilot Actions API",
    "version": "1.0.0",
    "description": "Copilot-facing action gateway for the Life Command Center. All actions route through a single gateway endpoint with typed schemas, tier-based confirmation, and full telemetry. LCC orchestrates; Copilot is a lens."
  },
  "servers": [
    {
      "url": "https://life-command-center-nine.vercel.app",
      "description": "Production"
    }
  ],
  "paths": {
    "/api/chat": {
      "post": {
        "operationId": "dispatchCopilotAction",
        "summary": "Copilot Action Gateway — dispatch any registered action",
        "description": "Single entry point for all Copilot actions. Validates action_id against the registry, enforces tier-based confirmation, routes internally, and logs telemetry.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "copilot_action": {
                    "type": "string",
                    "description": "Action ID from the registry",
                    "enum": [
                      "get_daily_briefing_snapshot",
                      "get_my_execution_queue",
                      "list_staged_intake_inbox",
                      "get_hot_business_contacts",
                      "search_entity_targets",
                      "get_pipeline_intelligence",
                      "draft_outreach_email",
                      "generate_prospecting_brief",
                      "get_sync_run_health",
                      "get_work_counts"
                    ]
                  },
                  "params": {
                    "type": "object",
                    "description": "Action-specific parameters (see individual action schemas)"
                  },
                  "surface": {
                    "type": "string",
                    "enum": [
                      "copilot_chat",
                      "teams",
                      "outlook",
                      "power_automate"
                    ],
                    "description": "Which Microsoft surface is calling"
                  }
                },
                "required": [
                  "copilot_action"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Action executed successfully or confirmation required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "source": {
                      "type": "string",
                      "const": "copilot_action_dispatch"
                    },
                    "data": {
                      "type": "object",
                      "description": "Action-specific response data"
                    },
                    "requires_confirmation": {
                      "type": "boolean",
                      "description": "True if action needs _confirmed: true"
                    },
                    "action": {
                      "type": "string"
                    },
                    "tier": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/portfolio/get-daily-briefing-snapshot": {
      "post": {
        "operationId": "get_daily_briefing_snapshot",
        "summary": "Get today's prioritized daily briefing with strategic, important, and urgent items requiring attention.",
        "description": "**Tier 0** (read-only). Category: portfolio.",
        "tags": [
          "portfolio"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "timeframe": {
                    "type": "string",
                    "enum": [
                      "today",
                      "since_yesterday",
                      "this_week"
                    ],
                    "description": "Time range for the briefing"
                  },
                  "domain": {
                    "type": "string",
                    "enum": [
                      "government",
                      "dialysis",
                      "both"
                    ],
                    "description": "Filter by business domain"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "briefing": {
                      "type": "object",
                      "description": "Structured briefing with priority sections"
                    },
                    "generated_at": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/portfolio/list-staged-intake-inbox": {
      "post": {
        "operationId": "list_staged_intake_inbox",
        "summary": "List inbox items awaiting triage — flagged emails, SF tasks, system alerts.",
        "description": "**Tier 0** (read-only). Category: portfolio.",
        "tags": [
          "portfolio"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "new",
                      "triaged",
                      "promoted",
                      "dismissed"
                    ],
                    "description": "Filter by inbox status"
                  },
                  "domain": {
                    "type": "string",
                    "enum": [
                      "government",
                      "dialysis"
                    ],
                    "description": "Filter by domain"
                  },
                  "source_type": {
                    "type": "string",
                    "enum": [
                      "flagged_email",
                      "sf_task",
                      "system",
                      "listing_bd_trigger"
                    ],
                    "description": "Filter by source"
                  },
                  "limit": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "description": "Max items to return"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "description": "Inbox items"
                    },
                    "count": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/portfolio/get-my-execution-queue": {
      "post": {
        "operationId": "get_my_execution_queue",
        "summary": "Get my prioritized work queue — open action items sorted by due date and priority.",
        "description": "**Tier 0** (read-only). Category: portfolio.",
        "tags": [
          "portfolio"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "domain": {
                    "type": "string",
                    "enum": [
                      "government",
                      "dialysis"
                    ],
                    "description": "Filter by domain"
                  },
                  "limit": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100
                  },
                  "order": {
                    "type": "string",
                    "description": "Sort order (e.g., sort_date.asc)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "description": "Prioritized work items"
                    },
                    "count": {
                      "type": "integer"
                    },
                    "view": {
                      "type": "string",
                      "const": "my_work"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/portfolio/get-hot-business-contacts": {
