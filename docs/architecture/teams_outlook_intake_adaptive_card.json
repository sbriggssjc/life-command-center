{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.4",
  "body": [
    {
      "type": "TextBlock",
      "text": "New Intake Item Captured",
      "weight": "Bolder",
      "size": "Medium"
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Sender",
          "value": "${sender}"
        },
        {
          "title": "Subject",
          "value": "${subject}"
        },
        {
          "title": "Run",
          "value": "${correlation_id}"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "${summary}",
      "wrap": true,
      "maxLines": 4,
      "spacing": "Small"
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "View in LCC",
      "url": "${lcc_item_url}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "Triage",
      "url": "${lcc_base_url}/?page=pageInbox&action=triage&inbox_id=${inbox_item_id}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "Assign",
      "url": "${lcc_base_url}/?page=pageInbox&action=assign&inbox_id=${inbox_item_id}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "Promote",
      "url": "${lcc_base_url}/?page=pageInbox&action=promote&inbox_id=${inbox_item_id}"
    }
  ]
}
