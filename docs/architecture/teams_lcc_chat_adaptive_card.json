{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.4",
  "body": [
    {
      "type": "TextBlock",
      "text": "LCC — ${action_label}",
      "weight": "Bolder",
      "color": "Accent",
      "size": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "${response_text}",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Asked by ${sender_name}",
      "size": "Small",
      "isSubtle": true,
      "spacing": "Medium"
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Open LCC",
      "url": "${lcc_base_url}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "Open My Queue",
      "url": "${lcc_base_url}/?page=pageMyWork"
    }
  ]
}
