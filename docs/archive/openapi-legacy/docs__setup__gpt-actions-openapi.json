{
  "openapi": "3.0.3",
  "info": {
    "title": "Life Command Center — GPT Actions API",
    "version": "1.0.0",
    "description": "GPT Actions gateway for the Life Command Center. Provides CRE deal intelligence, portfolio briefings, entity search, relationship context, pipeline analytics, prospecting briefs, and outreach drafting for Team Briggs net lease investment sales."
  },
  "servers": [
    {
      "url": "RAILWAY_URL",
      "description": "LCC Production (Railway)"
    }
  ],
  "paths": {
    "/api/copilot/portfolio/get-daily-briefing-snapshot": {
      "post": {
        "operationId": "get_daily_briefing_snapshot",
        "summary": "Get today's prioritized daily briefing with strategic, important, and urgent items.",
        "description": "Returns a structured morning briefing organized by priority: STRATEGIC (deal responses, listing pursuits), IMPORTANT (prospecting, seller updates), URGENT (inbox triage, sync health). Always start here when asked 'what should I focus on today?'",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "copilot_action": {
                    "type": "string",
                    "enum": ["get_daily_briefing_snapshot"],
                    "description": "Action identifier — must be 'get_daily_briefing_snapshot'"
                  },
                  "params": {
                    "type": "object",
                    "description": "Optional filters",
                    "properties": {
                      "timeframe": {
                        "type": "string",
                        "enum": ["today", "since_yesterday", "this_week"],
                        "description": "Time range for the briefing"
                      },
                      "domain": {
                        "type": "string",
                        "enum": ["government", "dialysis", "both"],
                        "description": "Filter by business domain"
                      }
                    }
                  }
                },
                "required": ["copilot_action"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Briefing returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "description": "Structured briefing with priority sections and generated_at timestamp"
                    },
                    "action": { "type": "string" },
                    "tier": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/portfolio/search-entity-targets": {
      "post": {
        "operationId": "search_entity_targets",
        "summary": "Search contacts, organizations, and assets by name.",
        "description": "Search canonical entities (contacts, organizations, assets) across all types and domains. Use this when the user asks to look up a person, company, or property by name.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "copilot_action": {
                    "type": "string",
                    "enum": ["search_entity_targets"],
                    "description": "Action identifier — must be 'search_entity_targets'"
                  },
                  "params": {
                    "type": "object",
                    "description": "Search parameters",
                    "properties": {
                      "q": {
                        "type": "string",
                        "description": "Search query (name match)"
                      },
                      "entity_type": {
                        "type": "string",
                        "enum": ["contact", "organization", "asset"],
                        "description": "Filter by entity type"
                      },
                      "domain": {
                        "type": "string",
                        "enum": ["government", "dialysis"],
                        "description": "Filter by business domain"
                      }
                    },
                    "required": ["q"]
                  }
                },
                "required": ["copilot_action", "params"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "description": "Object containing entities array and count"
                    },
                    "action": { "type": "string" },
                    "tier": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/portfolio/get-relationship-context": {
      "post": {
        "operationId": "get_relationship_context",
        "summary": "Get relationship context for a contact before a call or meeting.",
        "description": "Returns full relationship context for an entity: communication history, deal involvement, touchpoint cadence, and outreach recommendations. Use this to prepare for calls and meetings.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "copilot_action": {
                    "type": "string",
                    "enum": ["get_relationship_context"],
                    "description": "Action identifier — must be 'get_relationship_context'"
                  },
                  "params": {
                    "type": "object",
                    "description": "Entity to look up",
                    "properties": {
                      "entity_id": {
                        "type": "string",
                        "description": "Entity UUID from LCC database"
                      }
                    },
                    "required": ["entity_id"]
                  }
                },
                "required": ["copilot_action", "params"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Relationship context returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "description": "Relationship context with communication history and recommendations"
                    },
                    "action": { "type": "string" },
                    "tier": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/outreach/generate-prospecting-brief": {
      "post": {
        "operationId": "generate_prospecting_brief",
        "summary": "Generate a daily prospecting call sheet with ranked contacts.",
        "description": "AI-powered daily prospecting call sheet — ranks top contacts by engagement score with call prep notes and talking points. Use this when the user asks 'who should I call today?' or 'generate a call sheet'.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "copilot_action": {
                    "type": "string",
                    "enum": ["generate_prospecting_brief"],
                    "description": "Action identifier — must be 'generate_prospecting_brief'"
                  },
                  "params": {
                    "type": "object",
                    "description": "Optional parameters",
                    "properties": {
                      "limit": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 25,
                        "description": "Number of top contacts to include (default 10)"
                      }
                    }
                  }
                },
                "required": ["copilot_action"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prospecting brief generated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "description": "AI-generated call sheet with ranked contacts and prep notes"
                    },
                    "action": { "type": "string" },
                    "tier": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/portfolio/get-pipeline-intelligence": {
      "post": {
        "operationId": "get_pipeline_intelligence",
        "summary": "Get pipeline intelligence — deal velocity, conversion rates, bottlenecks.",
        "description": "Returns pipeline health metrics: deal velocity, conversion rates, bottleneck analysis across government and dialysis domains. Use when asked 'how is the pipeline?' or 'what deals are stuck?'.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "copilot_action": {
                    "type": "string",
                    "enum": ["get_pipeline_intelligence"],
                    "description": "Action identifier — must be 'get_pipeline_intelligence'"
                  },
                  "params": {
                    "type": "object",
                    "description": "Optional filters",
                    "properties": {
                      "domain": {
                        "type": "string",
                        "enum": ["government", "dialysis", "both"],
                        "description": "Filter by business domain"
                      },
                      "timeframe": {
                        "type": "string",
                        "enum": ["30d", "90d", "6m", "1y"],
                        "description": "Lookback period for analysis"
                      }
                    }
                  }
                },
                "required": ["copilot_action"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pipeline intelligence returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "description": "Pipeline metrics, deal counts, stage distribution, and bottleneck analysis"
                    },
                    "action": { "type": "string" },
                    "tier": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/copilot/outreach/draft-outreach-email": {
      "post": {
        "operationId": "draft_outreach_email",
        "summary": "Draft a personalized outreach email for a business development contact.",
        "description": "Generates a personalized outreach email draft using CRM data and relationship context. Provide contact_id or contact_name and an intent (reconnect, listing pitch, market update, etc.). The draft requires user review before sending.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "copilot_action": {
                    "type": "string",
                    "enum": ["draft_outreach_email"],
                    "description": "Action identifier — must be 'draft_outreach_email'"
                  },
                  "params": {
                    "type": "object",
                    "description": "Email parameters",
                    "properties": {
                      "contact_id": {
                        "type": "string",
                        "description": "Contact unified_id from the contacts database"
                      },
                      "contact_name": {
                        "type": "string",
                        "description": "Contact name (used if contact_id not available)"
                      },
                      "intent": {
                        "type": "string",
                        "description": "Purpose: reconnect, listing pitch, market update, follow-up, etc."
                      },
                      "tone": {
                        "type": "string",
                        "description": "Desired tone (default: professional, warm, and concise)"
                      }
                    }
                  }
                },
                "required": ["copilot_action"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email draft generated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "description": "Object containing subject, body, and provider fields"
                    },
                    "action": { "type": "string" },
                    "tier": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/context": {
      "post": {
        "operationId": "assemble_context_packet",
        "summary": "Assemble a context packet for a property, contact, deal, or pursuit.",
        "description": "Assembles a structured intelligence payload for a specific entity. Returns lease details, ownership history, comps, investment score, research status, and related contacts for properties; or touchpoint history and deal involvement for contacts. Use this for deep-dive lookups on specific entities.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": ["assemble"],
                    "description": "Must be 'assemble'"
                  },
                  "packet_type": {
                    "type": "string",
                    "enum": ["contact", "property", "pursuit", "deal", "daily_briefing"],
                    "description": "Type of context packet to assemble"
                  },
                  "entity_id": {
                    "type": "string",
                    "description": "UUID of the entity (required for all types except daily_briefing)"
                  },
                  "entity_type": {
                    "type": "string",
                    "description": "Optional entity type hint (contact, organization, asset)"
                  },
                  "force_refresh": {
                    "type": "boolean",
                    "description": "Skip cache and re-assemble (default false)"
                  }
                },
                "required": ["action", "packet_type"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Context packet assembled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "packet_type": { "type": "string" },
                    "entity_id": { "type": "string" },
                    "payload": {
                      "type": "object",
                      "description": "Assembled context data — structure varies by packet_type"
                    },
                    "assembled_at": { "type": "string" },
                    "cache_hit": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
