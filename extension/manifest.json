{
  "manifest_version": 3,
  "name": "LCC Assistant",
  "version": "1.0.3",
  "description": "Life Command Center context panel \u2014 Team Briggs CRE intelligence",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "contextMenus"
  ],
  "host_permissions": [
    "https://*.railway.app/*",
    "https://*.vercel.app/*",
    "https://*.supabase.co/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "https://*.costar.com/*",
    "https://*.csgpimgs.com/*",
    "https://*.salesforce.com/*",
    "https://*.crexi.com/*",
    "https://loopnet.com/*",
    "https://*.loopnet.com/*",
    "https://app.rcanalytics.com/*",
    "https://app2.rcanalytics.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*"
      ],
      "js": [
        "content/outlook.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.costar.com/*"
      ],
      "js": [
        "content/_sale-merge.js",
        "content/costar.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.salesforce.com/*"
      ],
      "js": [
        "content/salesforce.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://loopnet.com/*",
        "https://*.loopnet.com/*"
      ],
      "js": [
        "content/loopnet.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.crexi.com/*"
      ],
      "js": [
        "content/crexi.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://app.rcanalytics.com/*",
        "https://app2.rcanalytics.com/*"
      ],
      "js": [
        "content/rca.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open LCC Assistant"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_side_panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open LCC Assistant side panel"
    }
  }
}
