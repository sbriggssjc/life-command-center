OPS_SUPABASE_URL=
OPS_SUPABASE_KEY=
GOV_SUPABASE_URL=
GOV_SUPABASE_KEY=
# Optional (R30): enables the dia leg of the get_property_context address
# fallback + dia pipeline health. Unset = gov-only fallback (graceful no-op).
DIA_SUPABASE_URL=
DIA_SUPABASE_KEY=
LCC_API_KEY=
PORT=3100   # Port for the MCP HTTP server (/mcp endpoint)
MCP_BASE_URL=https://your-mcp-railway-domain.up.railway.app
# Primary workspace ID — used as the default when callers omit workspace_id in get_daily_briefing.
# Defaults to the production LCC workspace (a0000000-0000-0000-0000-000000000001) if unset.
LCC_PRIMARY_WORKSPACE_ID=a0000000-0000-0000-0000-000000000001
