# AI Chat balanced rollout preset for Life Command Center
#
# Use this as the first staged routing mix:
# - review-first intake and intel flows on local/low-cost models
# - ownership on stronger API reasoning
# - global copilot left on the legacy edge path initially

AI_CHAT_POLICY=balanced
AI_CHAT_PROVIDER=edge
AI_CHAT_MODEL=gpt-5-mini

# Feature-level provider overrides
AI_CHAT_FEATURE_PROVIDERS={"detail_ownership_assistant":"openai","global_copilot":"edge"}

# Feature-level model overrides
AI_CHAT_FEATURE_MODELS={"detail_intake_assistant":"llama3.2-vision","detail_intel_assistant":"llama3.1","ops_research_assistant":"llama3.1","detail_ownership_assistant":"gpt-5-mini"}

# OpenAI path requirements
# OPENAI_API_KEY=...

# Ollama path requirements
# AI_API_BASE_URL=http://localhost:11434
